{
  "name": "oogiri-bot",
  "version": "3.1.0",
  "description": "slack bot for oogiri",
  "author": "tocomi",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "release": "pnpm dlx release-it",
    "admin:dev": "pnpm --filter @oogiri-bot/admin dev",
    "admin:build": "pnpm --filter @oogiri-bot/admin build",
    "admin:start": "pnpm --filter @oogiri-bot/admin start",
    "admin:type-check": "pnpm --filter @oogiri-bot/admin type-check",
    "admin:lint": "pnpm --filter @oogiri-bot/admin lint",
    "admin:lint:fix": "pnpm --filter @oogiri-bot/admin lint:fix",
    "admin:format": "pnpm --filter @oogiri-bot/admin format",
    "admin:format:check": "pnpm --filter @oogiri-bot/admin format:check",
    "admin:test": "pnpm --filter @oogiri-bot/admin test",
    "admin:test:watch": "pnpm --filter @oogiri-bot/admin test:watch",
    "serve": "pnpm --filter @oogiri-bot/functions serve",
    "build": "pnpm --filter @oogiri-bot/functions build",
    "type-check": "pnpm --filter @oogiri-bot/functions type-check",
    "lint": "pnpm --filter @oogiri-bot/functions lint",
    "lint:fix": "pnpm --filter @oogiri-bot/functions lint:fix",
    "format": "pnpm --filter @oogiri-bot/functions format",
    "format:check": "pnpm --filter @oogiri-bot/functions format:check",
    "migrate": "pnpm --filter @oogiri-bot/functions migrate",
    "migrate:generate": "pnpm --filter @oogiri-bot/functions migrate:generate",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "pnpm --filter @oogiri-bot/functions test",
    "test:watch": "pnpm --filter @oogiri-bot/functions test:watch",
    "hooks:install": "lefthook install",
    "prepare": "node -e \"require('node:fs').existsSync('.git') && require('node:child_process').execSync('lefthook install', { stdio: 'inherit' })\""
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0"
  },
  "private": true
}
