{
  "name": "oogiri-bot",
  "version": "2.3.0",
  "description": "slack bot for oogiri",
  "main": "index.js",
  "author": "tocomi",
  "license": "MIT",
  "scripts": {
    "release": "npx release-it",
    "dev:api": "pnpm --filter api serve",
    "dev:bot": "pnpm --filter slackbot watch",
    "lint": "pnpm --filter api lint && pnpm --filter slackbot lint",
    "lint:fix": "pnpm --filter api lint:fix && pnpm --filter slackbot lint:fix",
    "format": "biome format --write",
    "migrate": "dotenv -e .env -- pnpm --filter api migrate",
    "deploy:api": "pnpm --filter api deploy",
    "deploy:bot": "pnpm --filter slackbot deploy:heroku",
    "type-check": "pnpm --filter api type-check && pnpm --filter slackbot type-check",
    "test": "pnpm --filter api test && pnpm --filter slackbot test"
  },
"devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "dotenv-cli": "^11.0.0",
    "@types/dotenv": "^8.2.0",
    "@types/node-fetch": "2.6.7",
    "@typescript-eslint/eslint-plugin": "^4.28.0",
    "@typescript-eslint/parser": "^4.28.0",
    "eslint": "^7.29.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.24.2",
    "eslint-plugin-unused-imports": "^1.1.4",
    "firebase-functions-test": "^0.2.0",
    "tsc-watch": "^4.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22.22.1"
  },
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "protobufjs"]
  }
}
