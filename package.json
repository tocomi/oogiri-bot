{
  "name": "oogiri-bot",
  "version": "2.3.0",
  "description": "slack bot for oogiri",
  "author": "tocomi",
  "license": "MIT",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "release": "npx release-it",
    "serve": "tsc-watch --onFirstSuccess 'firebase emulators:start --only functions'",
    "build": "tsc",
    "type-check": "echo '# type-check' && tsc --noEmit --diagnostics",
    "lint": "eslint --ext .js,.ts .",
    "lint:fix": "eslint --ext .js,.ts ./src --fix",
    "format": "biome format --write",
    "generate-types": "supabase gen types typescript --linked > src/generated/supabase.ts",
    "gcp-build": "echo 'no build step required'",
    "plugin": "echo dummyCommandForAvoidingFirebaseError",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@slack/bolt": "3",
    "@slack/web-api": "^6.2.4",
    "@supabase/supabase-js": "^2.101.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.0",
    "dotenv": "^10.0.0",
    "emoji-regex": "^9.0.0",
    "express": "^4.17.1",
    "firebase-admin": "^10.0.2",
    "firebase-functions": "^6.0.1",
    "openai": "^6.27.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "@types/cors": "^2.8.10",
    "@types/node-fetch": "2.6.7",
    "@types/uuid": "^10",
    "@typescript-eslint/eslint-plugin": "^4.28.0",
    "@typescript-eslint/parser": "^4.28.0",
    "eslint": "^7.29.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.24.2",
    "eslint-plugin-unused-imports": "^1.1.4",
    "tsc-watch": "^4.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  },
  "private": true
}
