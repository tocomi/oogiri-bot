{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "predeploy": [
      "pnpm --dir \"$RESOURCE_DIR\" run lint",
      "pnpm --dir \"$RESOURCE_DIR\" run build"
    ],
    "source": "apps/functions",
    "runtime": "nodejs22"
  },
  "emulators": {
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8081
    },
    "ui": {
      "enabled": true
    }
  }
}
