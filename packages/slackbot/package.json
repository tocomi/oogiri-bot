{
  "name": "slackbot",
  "version": "2.2.3",
  "description": "slack bot for oogiri",
  "main": "index.js",
  "author": "tocomi",
  "license": "MIT",
  "scripts": {
    "start": "node ./dist/index.js",
    "watch": "tsc-watch --onSuccess 'pnpm start'",
    "lint": "eslint --ext .js,.ts ./src",
    "lint:fix": "eslint --ext .js,.ts ./src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc",
    "type-check": "echo '# slackbot type-check' && tsc --noEmit --diagnostics",
    "deploy:heroku": "pnpm tsc && pnpm start"
  },
  "devDependencies": {
    "@types/node": "*",
    "typescript": "*"
  },
  "engines": {
    "node": ">=22.22.1"
  }
}
